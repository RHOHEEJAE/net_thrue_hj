# ============================================================
# Vercel 환경변수 설정 예시
# Vercel 대시보드 > Settings > Environment Variables 에 추가하세요.
# ============================================================

# Supabase PostgreSQL 연결 문자열 (Transaction mode, 포트 6543 사용)
# Supabase 대시보드 > Settings > Database > Connection string > Transaction 탭에서 복사
DATABASE_URL=postgresql://postgres.[PROJECT_REF]:[PASSWORD]@aws-0-[REGION].pooler.supabase.com:6543/postgres

# CORS 허용 도메인 (콤마로 구분, * 는 전체 허용)
# 운영 환경에서는 실제 도메인으로 제한하세요
ALLOWED_ORIGINS=https://your-app.vercel.app,https://ecommerce-dev.hectoinnovation.co.kr

# ============================================================
# 로컬 개발용 (DATABASE_URL 없을 때 사용)
# ============================================================
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=testdb
POSTGRES_USER=testuser
POSTGRES_PASSWORD=testpass
